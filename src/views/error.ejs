<%- include('layouts/header', { title: `Error ${typeof statusCode !=='undefined' ? statusCode : 500} | Willpig Studio`,
  extraStyles: `<style>
  .error-page {
  min-height: 70vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  }
  .error-card {
  text-align: center;
  max-width: 540px;
  padding: 3rem 2rem;
  border-radius: 16px;
  background: var(--bg-card, #fff);
  box-shadow: 0 4px 24px rgba(0,0,0,0.10);
  }
  .error-code {
  font-size: 5rem;
  font-weight: 800;
  line-height: 1;
  background: linear-gradient(135deg, #ff6b6b, #ee5a24);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 0.5rem;
  }
  .error-card h2 {
  font-size: 1.4rem;
  margin-bottom: 0.75rem;
  color: var(--text-primary, #222);
  }
  .error-card p {
  color: var(--text-muted, #666);
  margin-bottom: 1.5rem;
  line-height: 1.6;
  }
  .error-detail {
  background: var(--bg-alt, #f5f5f5);
  border-radius: 8px;
  padding: 1rem;
  margin-bottom: 1.5rem;
  text-align: left;
  font-size: 0.85rem;
  color: var(--text-muted, #888);
  word-break: break-word;
  border-left: 4px solid #ee5a24;
  }
  .error-detail strong {
  color: var(--text-primary, #333);
  display: block;
  margin-bottom: 0.4rem;
  }
  .error-actions {
  display: flex;
  gap: 10px;
  justify-content: center;
  flex-wrap: wrap;
  }
  .error-actions .btn {
  min-width: 140px;
  }
  </style>`
  }) %>

  <section class="error-page">
    <div class="error-card">
      <div class="error-code">
        <%= typeof statusCode !=='undefined' ? statusCode : 500 %>
      </div>
      <h2>
        <%= typeof errorTitle !=='undefined' ? errorTitle : 'Error interno del servidor' %>
      </h2>
      <p>
        <%= typeof message !=='undefined' && message ? message
          : 'Algo salió mal. Por favor, inténtalo de nuevo más tarde.' %>
      </p>

      <% if (typeof errorHint !=='undefined' && errorHint) { %>
        <div class="error-detail">
          <strong>Detalle del error:</strong>
          <%= errorHint %>
        </div>
        <% } %>

          <div class="error-actions">
            <a href="/"><button class="btn btn-primary">Volver al Inicio</button></a>
            <button class="btn btn-outline" onclick="history.back()">Regresar</button>
          </div>
    </div>
  </section>

  <%- include('layouts/footer') %>
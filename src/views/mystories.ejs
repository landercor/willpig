<%- include('layouts/header', { 
  title: 'Mis Historias | Willpig Studio',
  extraStyles: `<link rel="stylesheet" href="/css/modules/views/mystories.css">`
}) %>

<main class="library-page">
  <header class="library-header">
    <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
      <a href="/principal" class="back-link" style="color: var(--primary); font-weight: bold; text-decoration: none;"><img src="/img/img.ico/svg/arrow-left-short.svg" alt="principal">Principal</a>
      <h2>Mis Historias</h2>
    </div>
    <a href="/historias/crear" class="btn-savever">+ Nueva Historia</a>
  </header>

  <% 
    // Normalizamos la búsqueda por si en la DB viene en Mayúsculas/Minúsculas
    const published = stories.filter(s => s.estado && s.estado.toLowerCase() === 'publicado');
    const drafts = stories.filter(s => s.estado && s.estado.toLowerCase() === 'borrador');
  %>

  <div class="library-tabs">
    <button class="tab-btn active" data-target="published-tab">
      Publicadas (<%= published.length %>)
    </button>
    <button class="tab-btn" data-target="drafts-tab">
      Borradores (<%= drafts.length %>)
    </button>
  </div>

  <div class="library-content">

    <!-- === TAB: PUBLICADAS === -->
    <div id="published-tab" class="tab-content active">
      <div class="books-grid">
        <% if (published.length > 0) { %>
          <% published.forEach(historia => { %>
            <div class="book-card">
              <a href="/historias/<%= historia.id_cuento %>">
                <img src="<%= historia.portada_url || '/img/default-portada.jpg' %>" class="book-cover" alt="<%= historia.titulo %>">
              </a>
              <p class="book-title"><%= historia.titulo || 'Sin título' %></p>
              <div class="book-meta">
                <svg viewBox="0 0 16 16" width="10" height="8" fill="currentColor">
                  <path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0z" />
                  <path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8zm8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z" />
                </svg>
                <%= historia.vistas || 0 %> vistas
              </div>
              <div class="item-actions">
                <a href="/historias/editar/<%= historia.id_cuento %>">Editar</a>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="empty-state empty-state-full">
            <p>Aún no tienes historias publicadas.</p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- === TAB: BORRADORES === -->
    <div id="drafts-tab" class="tab-content">
      <div class="books-grid">
        <% if (drafts.length > 0) { %>
          <% drafts.forEach(historia => { %>
            <div class="book-card">
              <a href="/historias/editar/<%= historia.id_cuento %>">
                <span class="book-badge borrador">Borrador</span>
                <img src="<%= historia.portada_url || '/img/default-portada.jpg' %>" class="book-cover" alt="<%= historia.titulo %>">
              </a>
              <p class="book-title"><%= historia.titulo || 'Sin título' %></p>
              <div class="item-actions">
                <a href="/historias/editar/<%= historia.id_cuento %>">Continuar</a>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="empty-state empty-state-full">
            <p>No tienes borradores pendientes.</p>
          </div>
        <% } %>
      </div>
    </div>

  </div>
</main>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');

        // Remover 'active' de todos los botones y contenidos
        tabBtns.forEach(b => b.classList.remove('active'));
        tabContents.forEach(c => c.classList.remove('active'));

        // Activar el botón presionado y mostrar su pestaña correspondiente
        btn.classList.add('active');
        document.getElementById(targetId).classList.add('active');
      });
    });
  });
</script>

<%- include('layouts/footer') %>
<%- include('layouts/header', { title: `${cuento.titulo} | Willpig Studio` }) %>

<% const bgUrl = cuento.portada_url || '/img/default-bg.jpg'; %>
<% const authorAvatar = (cuento.cuenta_usuario && cuento.cuenta_usuario.avatar_url) ? cuento.cuenta_usuario.avatar_url : '/img/default-avatar.svg'; %>
<% const authorName = (cuento.cuenta_usuario && cuento.cuenta_usuario.username) ? cuento.cuenta_usuario.username : 'Autor'; %>
<% const authorId = cuento.cuenta_usuario && cuento.cuenta_usuario.id_cuenta_usuario; %>

<div class="story-page">
    <div class="story-container">
        <!-- Cabecera editorial -->
        <section class="story-hero">
            <img src="<%= cuento.portada_url || '/img/default-portada.jpg' %>" alt="Portada" class="story-cover">

            <div class="story-meta">
                <h1><%= cuento.titulo %></h1>

                <div class="author-badge">
                    <img src="<%= authorAvatar %>" alt="Avatar de @<%= authorName %>" onerror="this.src='/img/default-avatar.svg'">
                    <% if (authorId) { %>
                        <a href="/usuario/profile/<%= authorId %>" class="author-link">@<%= authorName %></a>
                    <% } else { %>
                        <span>@<%= authorName %></span>
                    <% } %>

                    <% if (loggerUser && authorId && String(loggerUser.id) !== String(authorId)) { %>
                        <button id="followBtn" class="btn-story-secondary <%= typeof isFollowing !== 'undefined' && isFollowing ? 'active' : '' %>"
                            data-authorid="<%= authorId %>">
                            <%= typeof isFollowing !== 'undefined' && isFollowing ? 'Siguiendo' : 'Seguir' %>
                        </button>
                    <% } %>
                </div>

                <div class="stats">
                    <span><img class="icon-stats" src="/img/img.ico/svg/eye-fill.svg" alt=""> <%= cuento.vistas || 0 %> lecturas</span>
                    <span><img class="icon-stats" src="/img/img.ico/svg/bookmark-heart-fill.svg" alt=""> <%= likesCount || 0 %> favoritos</span>
                    <span><img class="icon-stats" src="/img/img.ico/svg/book-half.svg" alt=""> <%= (cuento.capitulos || []).length %> partes</span>
                </div>

                <div class="story-actions">
                    <% if (cuento.capitulos && cuento.capitulos.length > 0) { %>
                        <a href="/capitulos/read/<%= cuento.capitulos[0].id_capitulo %>" class="btn-primary-pastel">Empezar a leer</a>
                    <% } else { %>
                        <button class="btn-primary-pastel" disabled>Próximamente</button>
                    <% } %>

                    <button id="likeBtn" class="btn-story-secondary <%= isLiked ? 'active-like' : '' %>" data-storyid="<%= cuento.id_cuento %>">
                        <span id="likesCount"><%= likesCount || 0 %></span> Me gusta
                    </button>

                    <% if (loggerUser) { %>
                        <button id="listBtn" class="btn-story-secondary <%= isInList ? 'active' : '' %>" data-storyid="<%= cuento.id_cuento %>">
                            <span id="listText"><%= isInList ? 'En mi lista' : 'Agregar a lista' %></span>
                        </button>
                    <% } %>
                </div>
            </div>
        </section>

        <!-- Pestañas Summary / Parts -->
        <nav class="story-tabs" role="tablist">
            <button class="story-tab active" data-tab="summary" role="tab" aria-selected="true">Resumen</button>
            <button class="story-tab" data-tab="parts" role="tab" aria-selected="false">Partes</button>
        </nav>

        <!-- Panel Resumen -->
        <section id="tab-summary" class="story-tab-panel active">
            <div class="story-meta-row">
                <span><img src="/img/img.ico/svg/book-half.svg" alt=""> <%= cuento.estado === 'publicado' ? 'Completo' : 'En progreso' %></span>
                <% if (cuento.categorias) { %>
                    <span class="story-tag"><%= cuento.categorias.nombre %></span>
                <% } %>
            </div>

            <p class="description"><%= cuento.descripcion || 'Sin descripción disponible.' %></p>
        </section>

        <!-- Panel Partes -->
        <section id="tab-parts" class="story-tab-panel">
            <h3 class="parts-heading">Tabla de contenidos</h3>
            <% if (cuento.capitulos && cuento.capitulos.length > 0) { %>
                <% cuento.capitulos.forEach(cap => { %>
                    <a href="/capitulos/read/<%= cap.id_capitulo %>" class="chapter-item">
                        <span><%= cap.titulo %></span>
                        <span class="chapter-date"><%= new Date(cap.created_at).toLocaleDateString('es-ES', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                    </a>
                <% }) %>
            <% } else { %>
                <p class="empty-parts">El autor aún no ha publicado capítulos.</p>
            <% } %>
        </section>

        <!-- Comentarios -->
        <section class="comments-section">
            <h3>
                <svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor"><path d="M14 1a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H4.414A2 2 0 0 0 3 11.586l-2 2V2a1 1 0 0 1 1-1h12zM2 0a2 2 0 0 0-2 2v12.793a.5.5 0 0 0 .854.353l2.853-2.853A1 1 0 0 1 4.414 12H14a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2z"/></svg>
                Comentarios <span id="commentCount" class="comment-count"></span>
            </h3>

            <% if (loggerUser) { %>
                <div class="comment-form">
                    <img src="<%= loggerUser.avatar || '/img/default-avatar.svg' %>" alt="Tu avatar" onerror="this.src='/img/default-avatar.svg'">
                    <div class="comment-form-body">
                        <textarea id="newCommentInput" placeholder="Escribe un comentario..." maxlength="1000"></textarea>
                        <div class="comment-form-footer">
                            <span id="charCount">0 / 1000</span>
                            <button id="submitComment" class="btn-primary-pastel">Publicar</button>
                        </div>
                    </div>
                </div>
            <% } else { %>
                <p class="comment-login-hint"><a href="/auth/login">Inicia sesión</a> para dejar un comentario.</p>
            <% } %>

            <div id="commentsList"></div>
        </section>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const storyId = '<%= cuento.id_cuento %>';
    const csrfToken = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';
    const currentUserId = '<%= loggerUser ? String(loggerUser.id_cuenta_usuario || loggerUser.id || "") : "" %>';

    // Tabs
    document.querySelectorAll('.story-tab').forEach(tab => {
        tab.addEventListener('click', () => {
            document.querySelectorAll('.story-tab').forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
            document.querySelectorAll('.story-tab-panel').forEach(p => p.classList.remove('active'));
            tab.classList.add('active');
            tab.setAttribute('aria-selected', 'true');
            document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
        });
    });

    const likeBtn = document.getElementById('likeBtn');
    if (likeBtn) {
        likeBtn.addEventListener('click', async () => {
            const isLiked = likeBtn.classList.contains('active-like');
            const url = isLiked ? `/social/unlike/${storyId}` : `/social/like/${storyId}`;
            const res = await fetch(url, { method: 'POST', headers: { 'CSRF-Token': csrfToken, 'Accept': 'application/json' } });
            if (res.ok) window.location.reload();
            else if (res.status === 401) window.location.href = '/auth/login';
        });
    }

    const listBtn = document.getElementById('listBtn');
    if (listBtn) {
        listBtn.addEventListener('click', async () => {
            const isInList = listBtn.classList.contains('active');
            const url = isInList ? `/social/lista/quitar/${storyId}` : `/social/lista/agregar/${storyId}`;
            const res = await fetch(url, { method: 'POST', headers: { 'CSRF-Token': csrfToken, 'Accept': 'application/json' } });
            if (res.ok) window.location.reload();
            else if (res.status === 401) window.location.href = '/auth/login';
        });
    }

    const followBtn = document.getElementById('followBtn');
    if (followBtn) {
        followBtn.addEventListener('click', async () => {
            const authorId = followBtn.getAttribute('data-authorid');
            const isFollowing = followBtn.classList.contains('active');
            const url = isFollowing ? `/social/dejar/${authorId}` : `/social/seguir/${authorId}`;
            const res = await fetch(url, { method: 'POST', headers: { 'CSRF-Token': csrfToken, 'Accept': 'application/json' } });
            if (res.ok) window.location.reload();
            else if (res.status === 401) window.location.href = '/auth/login';
        });
    }

    const submitComment = document.getElementById('submitComment');
    const commentInput = document.getElementById('newCommentInput');
    const charCount = document.getElementById('charCount');
    const commentsList = document.getElementById('commentsList');
    const commentCountEl = document.getElementById('commentCount');

    if (commentInput && charCount) {
        commentInput.addEventListener('input', () => { charCount.textContent = `${commentInput.value.length} / 1000`; });
    }

    if (submitComment && commentInput) {
        submitComment.addEventListener('click', async () => {
            const contenido = commentInput.value.trim();
            if (!contenido) return;
            submitComment.disabled = true;
            const res = await fetch(`/social/comentarios/${storyId}`, {
                method: 'POST',
                headers: { 'CSRF-Token': csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify({ contenido })
            });
            if (res.ok) { commentInput.value = ''; if (charCount) charCount.textContent = '0 / 1000'; loadComments(); }
            else if (res.status === 401) window.location.href = '/auth/login';
            submitComment.disabled = false;
        });
    }

    async function loadComments() {
        if (!commentsList) return;
        commentsList.innerHTML = '<p class="loading-comments">Cargando comentarios...</p>';
        try {
            const res = await fetch(`/social/comentarios/${storyId}`);
            const data = await res.json();
            if (commentCountEl) commentCountEl.textContent = data.comentarios?.length ? `(${data.comentarios.length})` : '';
            if (!data.comentarios?.length) {
                commentsList.innerHTML = '<p class="empty-comments">No hay comentarios todavía. ¡Sé el primero!</p>';
                return;
            }
            commentsList.innerHTML = data.comentarios.map(c => {
              const commentOwnerId = c.usuario_id || c.cuenta_usuario?.id_cuenta_usuario || '';
              const isOwn = currentUserId && String(commentOwnerId) === String(currentUserId);
              const safeCommentId = String(c.id || '').replace(/'/g, "\\'");
              return `
                <div class="comment-item" data-comment-id="${c.id}">
                    <img src="${(c.cuenta_usuario && c.cuenta_usuario.avatar_url) || '/img/default-avatar.svg'}" alt="" onerror="this.src='/img/default-avatar.svg'">
                    <div style="flex:1">
                        <div class="comment-meta">
                            <strong>@${c.cuenta_usuario ? c.cuenta_usuario.username : 'Usuario'}</strong>
                            <span>${new Date(c.created_at).toLocaleDateString('es-ES')}</span>
                            ${isOwn ? `<button class="btn-delete-comment" type="button" onclick="deleteComment('${safeCommentId}')">Eliminar</button>` : ''}
                        </div>
                        <p>${c.contenido}</p>
                    </div>
                </div>`;
            }).join('');
        } catch (_) {
            commentsList.innerHTML = '<p class="error-comments">Error al cargar comentarios.</p>';
        }
    }
    loadComments();

    // Eliminar comentario propio
    window.deleteComment = async function(commentId) {
        if (!confirm('\u00bfEliminar este comentario?')) return;
        try {
            const res = await fetch(`/social/comentarios/borrar/${commentId}`, {
                method: 'DELETE',
                headers: { 'CSRF-Token': csrfToken, 'Accept': 'application/json' }
            });
            if (res.ok) loadComments();
            else {
                const d = await res.json().catch(() => ({}));
                alert(d.error || 'No se pudo eliminar el comentario.');
            }
        } catch (_) { alert('Error de red.'); }
    };
});
</script>
<%- include('layouts/footer') %>

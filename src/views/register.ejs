<%- include('layouts/header', { title: 'Registrarse | Willpig Studio' , pageId: 'register' }) %>
    <main class="register-container-igm">
        <div class="register-card">
            <h1>Crear una cuenta</h1>
            <p>Únete a Willpig Studio y comparte tus historias ilustradas.</p>

            <!-- Mostrar error si existe -->
            <% if (typeof error !=="undefined" ) { %>
                <p style="color:red; text-align:center; margin-bottom:10px;">
                    <%= error %>
                </p>
                <% } %>

                    <% if (typeof success !=="undefined" ) { %>
                        <div class="success-message">
                            <%= success %>
                        </div>
                        <% } %>

                            <form action="/auth/register" method="POST" class="register-form">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <input type="hidden" name="next" value="<%= typeof next !== 'undefined' ? next : '' %>">
                                <div class="form-group">
                                    <label for="username">Nombre de usuario</label>
                                    <input type="text" id="username" name="username" placeholder="Tu nombre" required />
                                </div>

                                <div class="form-group">
                                    <label for="correo">Correo electrónico</label>
                                    <input type="email" id="correo" name="correo" placeholder="ejemplo@email.com"
                                        required />
                                </div>

                                <div class="form-group">
                                    <label for="contrasena">Contraseña</label>
                                    <input type="password" id="contrasena" name="contrasena"
                                        placeholder="Crea una contraseña segura" required />
                                    <small style="display:block; margin-top:6px; color:#6b7280; font-size:0.85rem; line-height:1.3;">
                                        Usa al menos 8 caracteres, una mayúscula, una minúscula y un número.
                                    </small>
                                </div>

                                <div class="form-group"
                                    style="display: flex; align-items: center; gap: 10px; margin-top: 15px; margin-bottom: 15px;">
                                    <input type="checkbox" id="terminos" name="terminos" required
                                        style="width: auto; margin: 0; cursor: pointer;">
                                    <label for="terminos"
                                        style="margin: 0; font-size: 0.9em; font-weight: normal; cursor: pointer;">
                                        He leído y acepto los <a href="/auth/register#terms-modal" id="open-terms-modal"
                                            style="color: #ff6b6b; text-decoration: underline;">Términos y
                                            Condiciones</a>
                                    </label>
                                </div>

                                <button type="submit" class="btn-register">Registrarse</button>
                            </form>

                            <div class="divider"> O continúa con </div>

                            <div class="social-login">
                                <a href="/auth/google" style="text-decoration: none; width: 100%;">
                                    <button type="button" class="social-btn google">
                                        <img src="/img/img.ico/google_login_color.png" width="20" alt="Google logo">
                                        Continuar con Google
                                    </button>
                                </a>
                            </div>
                            <p class="login-link">
                                ¿Ya tienes cuenta? <a href="/auth/login"><strong>Inicia sesión</strong></a>
                            </p>
        </div>
    </main>



    <%- include('layouts/footer') %>
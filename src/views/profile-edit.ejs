<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Editar perfil | Willpig Studio</title>
  <link rel="stylesheet" href="/css/style1.2.css">
  <link rel="icon" href="/img/img.ico/GABALI baloo.ico">
  <style>
    .edit-page {
      max-width: 680px;
      margin: 40px auto;
      padding: 0 20px 60px;
    }
    .edit-page h1 {
      font-size: 1.6rem;
      font-weight: 700;
      margin-bottom: 6px;
      color: var(--text-primary, #e2e2e2);
    }
    .edit-page .subtitle {
      color: var(--text-muted, #888);
      font-size: 0.875rem;
      margin-bottom: 32px;
    }
    .edit-card {
      background: var(--bg-card, rgba(255,255,255,0.04));
      border: 1px solid var(--border, rgba(255,255,255,0.08));
      border-radius: 18px;
      padding: 28px;
      margin-bottom: 20px;
    }
    .edit-card h2 {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted, #888);
      margin: 0 0 18px;
    }

    /* IMAGE PREVIEW */
    .img-preview-row {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 16px;
    }
    .preview-circle {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid var(--border, rgba(255,255,255,0.12));
    }
    .preview-banner {
      width: 100%;
      height: 110px;
      object-fit: cover;
      border-radius: 12px;
      border: 2px solid var(--border, rgba(255,255,255,0.1));
      margin-bottom: 12px;
    }
    .file-upload-label {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 8px 18px;
      border-radius: 20px;
      border: 1.5px solid var(--border, rgba(255,255,255,0.15));
      color: var(--text-primary, #e2e2e2);
      font-size: 0.82rem;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
    }
    .file-upload-label:hover {
      border-color: var(--accent, #a78bfa);
      background: rgba(167,139,250,0.08);
    }
    .file-upload-label input[type="file"] { display: none; }

    /* FORM FIELDS */
    .field-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 18px;
    }
    .field-group:last-child { margin-bottom: 0; }
    .field-label {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text-secondary, #aaa);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .field-input, .field-textarea {
      width: 100%;
      background: var(--bg, rgba(255,255,255,0.05));
      border: 1.5px solid var(--border, rgba(255,255,255,0.1));
      border-radius: 10px;
      color: var(--text-primary, #e2e2e2);
      font-size: 0.925rem;
      padding: 10px 14px;
      transition: border-color 0.2s;
      box-sizing: border-box;
      font-family: inherit;
    }
    .field-input:focus, .field-textarea:focus {
      outline: none;
      border-color: var(--accent, #a78bfa);
    }
    .field-textarea {
      resize: vertical;
      min-height: 110px;
      line-height: 1.6;
    }
    .char-count {
      font-size: 0.75rem;
      color: var(--text-muted, #666);
      text-align: right;
    }

    /* ACTIONS */
    .form-actions {
      display: flex;
      gap: 12px;
      justify-content: flex-end;
      flex-wrap: wrap;
    }
    .btn-save {
      padding: 11px 28px;
      border-radius: 24px;
      background: var(--accent, #a78bfa);
      color: #fff;
      font-size: 0.9rem;
      font-weight: 600;
      border: none;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.2s;
    }
    .btn-save:hover { opacity: 0.87; transform: translateY(-1px); }
    .btn-cancel {
      padding: 11px 22px;
      border-radius: 24px;
      background: transparent;
      color: var(--text-secondary, #aaa);
      font-size: 0.9rem;
      font-weight: 500;
      border: 1.5px solid var(--border, rgba(255,255,255,0.12));
      cursor: pointer;
      text-decoration: none;
      transition: border-color 0.2s;
    }
    .btn-cancel:hover { border-color: var(--text-muted, #888); }
  </style>
</head>
<body>
  <%- include('partials/navbar', { loggerUser }) %>

  <div class="edit-page">
    <h1>✏️ Editar perfil</h1>
    <p class="subtitle">Personaliza cómo te ven los demás lectores.</p>

    <form action="/usuario/perfil/editar" method="POST" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <!-- IMÁGENES -->
      <div class="edit-card">
        <h2>📷 Foto de perfil</h2>
        <div class="img-preview-row">
          <img id="avatarPreview"
            class="preview-circle"
            src="<%= userData.avatar_url || '/img/default-avatar.svg' %>"
            alt="Avatar actual">
          <label class="file-upload-label">
            📁 Cambiar foto
            <input type="file" name="avatar" accept="image/*" id="avatarInput">
          </label>
        </div>
      </div>

      <div class="edit-card">
        <h2>🖼️ Banner / Portada de fondo</h2>
        <img id="bannerPreview"
          class="preview-banner"
          src="<%= userData.portada_url || '/img/default-cover.jpg' %>"
          alt="Banner actual"
          onerror="this.style.display='none'">
        <br>
        <label class="file-upload-label">
          📁 Cambiar banner
          <input type="file" name="coverImage" accept="image/*" id="bannerInput">
        </label>
      </div>

      <!-- BIO -->
      <div class="edit-card">
        <h2>📝 Descripción / Biografía</h2>
        <div class="field-group">
          <label class="field-label">Cuéntale al mundo quién eres</label>
          <textarea
            class="field-textarea"
            name="biografia"
            id="bioField"
            maxlength="400"
            placeholder="Ej: Escritora de fantasía oscura, amante del café y los finales inesperados..."><%= userData.biografia || '' %></textarea>
          <span class="char-count"><span id="bioCount"><%= (userData.biografia || '').length %></span>/400</span>
        </div>
      </div>

      <!-- ACCIONES -->
      <div class="form-actions">
        <a href="/usuario/perfil" class="btn-cancel">Cancelar</a>
        <button type="submit" class="btn-save">💾 Guardar cambios</button>
      </div>
    </form>
  </div>

  <script>
    // Preview de imágenes al seleccionar
    document.getElementById('avatarInput').addEventListener('change', function () {
      if (this.files[0]) {
        document.getElementById('avatarPreview').src = URL.createObjectURL(this.files[0]);
      }
    });
    document.getElementById('bannerInput').addEventListener('change', function () {
      const preview = document.getElementById('bannerPreview');
      if (this.files[0]) {
        preview.src = URL.createObjectURL(this.files[0]);
        preview.style.display = 'block';
      }
    });

    // Contador de caracteres en bio
    const bioField = document.getElementById('bioField');
    const bioCount = document.getElementById('bioCount');
    bioField.addEventListener('input', () => {
      bioCount.textContent = bioField.value.length;
    });
  </script>

  <%- include('partials/footer') %>
</body>
</html>

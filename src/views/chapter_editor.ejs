<%- include('layouts/header', { 
  title: `Editor: ${typeof storyTitle !== 'undefined' ? storyTitle : 'Capítulo'} | Willpig Studio`,
  extraStyles: `
    <link rel="stylesheet" href="https://cdn.quilljs.com/1.3.6/quill.snow.css">
    <link rel="stylesheet" href="/css/workEdit.css">
  `
}) %>

<div class="editor-container">
  <div class="editor-header">
    <span class="story-label">Escribiendo para: <%= typeof storyTitle !== 'undefined' ? storyTitle : 'Historia' %></span>
    <input type="text" id="chapter-title" class="chapter-title-input" placeholder="Título del capítulo..."
      value="<%= chapter && chapter.titulo ? chapter.titulo : '' %>">
  </div>

  <div id="editor">
    <%- (chapter && chapter.contenido) ? chapter.contenido : '' %>
  </div>

  <div class="editor-footer">
    <a href="/historias/editar/<%= chapter ? chapter.cuento_id : '' %>" class="btn-cancel">Cancelar</a>
    <button id="save-btn" class="btn-savever" style="padding: 12px 30px; border-radius: 25px;">
      <%= (chapter && chapter.id_capitulo) ? 'Guardar Cambios' : 'Publicar Capítulo' %>
    </button>
  </div>
</div>

<!-- Quill JS -->
<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

<script>
  // Inicialización de Quill
  var quill = new Quill('#editor', {
    theme: 'snow',
    placeholder: 'Empieza a escribir tu historia...',
    modules: {
      toolbar: [
        [{ 'header': [1, 2, 3, false] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ 'list': 'ordered' }, { 'list': 'bullet' }],
        ['blockquote', 'code-block'],
        ['clean']
      ]
    }
  });

  const saveBtn = document.getElementById('save-btn');
  const chapterId = '<%= (chapter && chapter.id_capitulo) ? chapter.id_capitulo : "" %>';
  const storyId = '<%= (chapter && chapter.cuento_id) ? chapter.cuento_id : "" %>';
  const csrfToken = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';

  saveBtn.addEventListener('click', async () => {
    const titulo = document.getElementById('chapter-title').value.trim();
    const contenido = quill.root.innerHTML;

    if (!titulo) {
      alert('Por favor, ponle un título al capítulo');
      return;
    }

    saveBtn.disabled = true;
    saveBtn.innerText = 'Guardando...';

    try {
      let url = '/capitulos/new';
      let method = 'POST';

      if (chapterId) {
        url = `/capitulos/update/${chapterId}`;
        method = 'PUT';
      }

      const res = await fetch(url, {
        method: method,
        headers: { 
          'Content-Type': 'application/json', 
          'X-CSRF-Token': csrfToken, 
          'Accept': 'application/json' 
        },
        body: JSON.stringify({ titulo, contenido, cuento_id: storyId })
      });

      if (res.ok) {
        window.location.href = `/historias/editar/${storyId}`;
      } else {
        const errorData = await res.json().catch(() => ({}));
        alert(errorData.message || 'Error al guardar el capítulo');
        saveBtn.disabled = false;
        saveBtn.innerText = 'Reintentar';
      }
    } catch (err) {
      console.error(err);
      alert('Error de conexión con el servidor');
      saveBtn.disabled = false;
      saveBtn.innerText = 'Reintentar';
    }
  });
</script>

<!-- Global Scripts -->
<script src="/js/script.js"></script>

<%- include('layouts/footer') %>
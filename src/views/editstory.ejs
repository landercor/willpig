<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Editar historia | Willpig Studio</title>
  <link rel="stylesheet" href="/css/style1.2.css" />
  <link rel="icon" href="/img/img.ico/GABALI baloo.ico" />
</head>

<body>

  <%- include('partials/navbar', { loggerUser }) %>

    <!-- Barra superior -->
    <header class="story-header">
      <div class="header-left">
        <a href="javascript:history.back()" class="back-link">← Volver</a>
        <h2>Agregar información de la historia</h2>
      </div>

      <div class="header-actions">
        <a href="javascript:history.back()" class="btn-canceler">Cancelar</a>
        <button type="submit" form="story-form" class="btn-savever">Guardar</button>
      </div>
    </header>

    <main class="new-storys">

      <!-- Portada -->
      <div class="story-cover">
        <label for="portada" class="cover-box">
          <% if (cuento.portada_url) { %>
            <img src="<%= cuento.portada_url %>" style="width:100%; height:100%; object-fit:cover; border-radius:12px;">
            <% } else { %>
              <img src="/img/img.ico/image-icon.png" class="cover-icon">
              <p>Cambiar portada</p>
              <% } %>
        </label>
        <input type="file" id="portada" name="portada" accept="image/*" form="story-form" hidden>
      </div>

      <!-- Formulario -->
      <form id="story-form" class="story-form" action="/historias/editar/<%= cuento.id_cuento %>" method="POST"
        enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <section class="story-details">
          <h3>Detalles de la historia</h3>

          <div class="form-group">
            <label for="titulo">Título</label>
            <input type="text" id="titulo" name="titulo" value="<%= cuento.titulo %>" required>
          </div>

          <div class="form-group">
            <label for="descripcion">Descripción</label>
            <textarea id="descripcion" name="descripcion"><%= cuento.descripcion %></textarea>
          </div>

          <div class="form-group">
            <label for="audiencia">Audiencia</label>
            <select id="audiencia" name="audiencia" required>
              <% audiencias.forEach(a => { %>
                <option value="<%= a.nombre %>" <%=cuento.audiencia===a.nombre ? 'selected' : '' %>><%= a.nombre %></option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label for="idioma">Idioma</label>
            <select id="idioma" name="idioma" required>
              <% idiomas.forEach(i => { %>
                <option value="<%= i.codigo %>" <%=cuento.idioma===i.codigo ? 'selected' : '' %>><%= i.nombre %></option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label for="derechos">Derechos de autor</label>
            <select id="derechos" name="derechos" required>
              <% tiposDerechos.forEach(d => { %>
                <option value="<%= d.nombre %>" <%=cuento.derechos===d.nombre ? 'selected' : '' %>><%= d.nombre %></option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label for="categoria">Categoría</label>
            <select id="categoria" name="categoria_id" required>
              <option value="">Selecciona una categoría</option>
              <% categorias.forEach(cat => { %>
                <option value="<%= cat.id_categoria %>" <%= cuento.categoria_id == cat.id_categoria ? 'selected' : '' %>><%= cat.nombre %></option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label>Clasificación</label>
            <% clasificaciones.forEach(c => { %>
              <label><input type="radio" name="clasificacion" value="<%= c.nombre %>" <%=cuento.clasificacion===c.nombre ? 'checked' : '' %>> <%= c.nombre %></label>
            <% }) %>
          </div>

          <div class="form-group">
            <label>Visibilidad</label>
            <label><input type="radio" name="visibilidad" value="publica" <%=cuento.visibilidad==='publica' ? 'checked' : '' %>> Público</label>
            <label><input type="radio" name="visibilidad" value="privada" <%=cuento.visibilidad==='privada' ? 'checked' : '' %>> Privado</label>
          </div>

          <div class="form-group">
            <label>Estado de la obra</label>
            <% estadosCuento.forEach(e => { %>
              <label><input type="radio" name="estado" value="<%= e.nombre %>" <%=cuento.estado===e.nombre ? 'checked' : '' %>> <%= e.nombre %></label>
            <% }) %>
          </div>

        </section>
      </form>
    </main>

    <%- include('partials/footer') %>

    <script>
      const input = document.getElementById("portada");
      const label = document.querySelector(".cover-box");

      input.addEventListener("change", function () {
        const file = this.files[0];
        if (file) {
          const imgURL = URL.createObjectURL(file);
          label.innerHTML = `<img src="${imgURL}" style="width:100%; height:100%; object-fit:cover; border-radius:12px;">`;
        }
      });

      // Success Alert Logic
      window.addEventListener('DOMContentLoaded', () => {
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('success')) {
          const toastContainer = document.createElement('div');
          toastContainer.className = 'toast-container';
          document.body.appendChild(toastContainer);

          const toast = document.createElement('div');
          toast.className = 'toast toast-success';
          toast.innerHTML = `
            <svg width="24" height="24" fill="#4CAF50" viewBox="0 0 24 24">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
            </svg>
            <span>¡Historia creada correctamente!</span>
          `;
          
          toastContainer.appendChild(toast);

          // Remove after 5 seconds
          setTimeout(() => {
            toast.classList.add('fade-out');
            setTimeout(() => toast.remove(), 500);
          }, 4000);
          
          // Clean URL without reloading
          const newUrl = window.location.pathname;
          window.history.replaceState({}, document.title, newUrl);
        }
      });
    </script>
</body>
</html>
<%- include('layouts/header', { 
  title: `Editar historia | Willpig Studio`
}) %>

<!-- Barra superior -->
    <header class="story-header">
      <div class="header-left">
        <a href="javascript:history.back()" class="back-link">
          <img src="/img/img.ico/svg/arrow-left-short.svg" alt="Volver" style="width:18px; height:18px;">
          <span>Volver</span>
        </a>
        <h2>Agregar información de la historia</h2>
      </div>

      <div class="header-actions">
        <a href="javascript:history.back()" class="btn-canceler">Cancelar</a>
        <button type="submit" form="story-form" class="btn-savever">Guardar</button>
      </div>
    </header>

    <main class="new-storys">

      <!-- Portada -->
      <div class="story-cover">
        <label for="portada" class="cover-box">
          <% if (cuento.portada_url) { %>
            <img id="cover-preview" src="<%= cuento.portada_url %>" alt="Vista previa de portada" style="width:100%; height:100%; object-fit:cover; border-radius:12px;">
            <p id="cover-helper-text" style="display:none;">Cambiar portada</p>
            <% } else { %>
              <img id="cover-preview" src="/img/img.ico/image-icon.png" class="cover-icon" alt="Vista previa de portada" style="width:72px; height:72px; object-fit:contain;">
              <p id="cover-helper-text">Cambiar portada</p>
              <% } %>
        </label>
        <input type="file" id="portada" name="portada" accept="image/*" form="story-form" hidden onchange="previewCover(this, 'cover-preview', 'cover-helper-text')">
      </div>

      <!-- Formulario -->
      <form id="story-form" class="story-form" action="/historias/editar/<%= cuento.id_cuento %>" method="POST"
        enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <section class="story-details">
      <% 
        /* Helper: el DB guarda formas cortas ('general','todos','borrador');
           normStr permite comparar aunque el nombre en DB sea largo ('Todos los...').
           Verifica que la forma corta guardada esté contenida en el nombre normalizado. */
        const normStr = s => String(s||'').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
      %>
      <h3>Detalles de la historia</h3>

          <div class="form-group">
            <label for="titulo">Título</label>
            <input type="text" id="titulo" name="titulo" value="<%= cuento.titulo %>" required>
          </div>

          <div class="form-group">
            <label for="descripcion">Descripción</label>
            <textarea id="descripcion" name="descripcion"><%= cuento.descripcion %></textarea>
          </div>

          <div class="form-group">
            <label for="audiencia">Audiencia</label>
            <select id="audiencia" name="audiencia" required>
              <% audiencias.forEach(a => { %>
                <option value="<%= a.nombre %>" <%= normStr(a.nombre).includes(cuento.audiencia||'') ? 'selected' : '' %>><%= a.nombre %></option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label for="idioma">Idioma</label>
            <select id="idioma" name="idioma" required>
              <% idiomas.forEach(i => { %>
                <option value="<%= i.codigo %>" <%=cuento.idioma===i.codigo ? 'selected' : '' %>><%= i.nombre %></option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label for="derechos">Derechos de autor</label>
            <select id="derechos" name="derechos" required>
              <% tiposDerechos.forEach(d => { %>
                <option value="<%= d.nombre %>" <%= normStr(d.nombre).includes(cuento.derechos||'') ? 'selected' : '' %>><%= d.nombre %></option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label for="categoria">Categoría</label>
            <select id="categoria" name="categoria_id" required>
              <option value="">Selecciona una categoría</option>
              <% categorias.forEach(cat => { %>
                <option value="<%= cat.id_categoria %>" <%= cuento.categoria_id == cat.id_categoria ? 'selected' : '' %>><%= cat.nombre %></option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label>Clasificación</label>
            <% clasificaciones.forEach(c => { %>
              <label><input type="radio" name="clasificacion" value="<%= c.nombre %>" <%= normStr(c.nombre).includes(cuento.clasificacion||'') ? 'checked' : '' %>> <%= c.nombre %></label>
            <% }) %>
          </div>

          <div class="form-group">
            <label>Visibilidad</label>
            <label><input type="radio" name="visibilidad" value="publica" <%=cuento.visibilidad==='publica' ? 'checked' : '' %>> Público</label>
            <label><input type="radio" name="visibilidad" value="privada" <%=cuento.visibilidad==='privada' ? 'checked' : '' %>> Privado</label>
          </div>

          <div class="form-group">
            <label>Estado de la obra</label>
            <% estadosCuento.forEach(e => { %>
              <label><input type="radio" name="estado" value="<%= e.nombre %>" <%= normStr(e.nombre).includes(cuento.estado||'') ? 'checked' : '' %>> <%= e.nombre %></label>
            <% }) %>
          </div>

        </section>
      </form>
    </main>

    <script>
      function previewCover(input, previewId, helperId) {
        const preview = document.getElementById(previewId);
        const helper = document.getElementById(helperId);
        if (!input.files || !input.files[0]) return;

        const file = input.files[0];
        if (!file.type.startsWith('image/')) return;

        const reader = new FileReader();
        reader.onload = function (event) {
          preview.src = event.target.result;
          preview.style.width = '100%';
          preview.style.height = '100%';
          preview.style.objectFit = 'cover';
          preview.style.borderRadius = '12px';
          if (helper) helper.style.display = 'none';
        };
        reader.readAsDataURL(file);
      }
    </script>

    <%- include('layouts/footer') %>
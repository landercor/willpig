<%- include('layouts/header', { 
  title: `Gestionar:  | Willpig Studio`,
  extraStyles: `<link rel="stylesheet" href="/css/workEdit.css">`
}) %>

<div class="manage-container">
            <div style="margin-bottom: 20px; display: flex; gap: 16px; align-items: center; font-size: 0.95rem; flex-wrap: wrap;">
                <a href="/historias/mis" class="back-link" style="color: var(--primary); font-weight: bold; text-decoration: none; display: flex; align-items: center; gap: 4px;">
                    <img src="/img/img.ico/svg/arrow-left-short.svg" alt="left-arrow" style="width: 20px; height: 20px;">
                    <span>Mis Historias</span>
                </a>
                <span style="color: #4b5563;">|</span>
                <a href="/principal" class="back-link" style="color: #9ca3af; text-decoration: none; display: flex; align-items: center; gap: 4px; transition: color 0.2s;">
                    <span>Ir al Principal</span>
                </a>
            </div>
            <header class="manage-header">
                <img src="<%= cuento.portada_url || '/img/default-portada.jpg' %>" alt="Portada" class="manage-cover">
                <div class="manage-info">
                    <span class="badge <%= cuento.estado %>">
                        <%= cuento.estado %>
                    </span>
                    <h1>
                        <%= cuento.titulo %>
                    </h1>
                    <p>
                        <%= cuento.descripcion %>
                    </p>

                    <div class="action-bar">
                        <a href="/historias/editar-meta/<%= cuento.id_cuento %>" class="btn-edit-small">Editar Información</a>
                        <a href="/historias/editar-meta/<%= cuento.id_cuento %>" class="btn-edit-small">Cambiar Portada</a>
                        <% if (cuento.estado==='borrador' ) { %>
                            <form method="POST" action="/historias/editar/<%= cuento.id_cuento %>" enctype="multipart/form-data" style="display:inline">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                              <input type="hidden" name="titulo" value="<%= cuento.titulo %>">
                              <input type="hidden" name="descripcion" value="<%= cuento.descripcion || '' %>">
                              <input type="hidden" name="estado" value="publicado">
                              <input type="hidden" name="visibilidad" value="publica">
                              <input type="hidden" name="audiencia" value="<%= cuento.audiencia || 'general' %>">
                              <input type="hidden" name="idioma" value="<%= cuento.idioma || 'es' %>">
                              <input type="hidden" name="derechos" value="<%= cuento.derechos || 'todos' %>">
                              <input type="hidden" name="clasificacion" value="<%= cuento.clasificacion || 'todo' %>">
                              <input type="hidden" name="categoria_id" value="<%= cuento.categoria_id || 1 %>">
                              <button type="submit" class="btn-savever">Publicar Historia</button>
                            </form>
                            <% } %>
                    </div>
                </div>
            </header>

            <section class="chapters-section">
                <div class="section-header">
                    <h3>Capítulos (<%= cuento.capitulos ? cuento.capitulos.length : 0 %>)</h3>
                    <a href="/capitulos/nuevo/<%= cuento.id_cuento %>" class="btn-savever">+ Escribir Capítulos</a>
                </div>
                <div class="chapter-list">
                    <% if (cuento.capitulos && cuento.capitulos.length> 0) { %>
                        <% cuento.capitulos.forEach((cap, index)=> { %>
                            <div class="chapter-list-item">
                                <div class="chapter-info">
                                    <h4>Capítulo <%= index + 1 %>: <%= cap.titulo %>
                                    </h4>
                                    <span>Publicado el <%= new Date(cap.created_at).toLocaleDateString() %></span>
                                </div>
                                <div class="chapter-actions">
                                    <a href="/capitulos/editar/<%= cap.id_capitulo %>"
                                        class="btn-small btn-edit">Editar</a>
                                    <button onclick="deleteChapter('<%= cap.id_capitulo %>')"
                                        class="btn-small btn-delete">Eliminar</button>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="empty-chapters">
                            <p>Aún no has escrito ningún capítulo para esta historia.</p>
                            <p class="subtitle">¡Empieza hoy mismo!</p>
                        </div>
                    <% } %>
                </div>
            </section>
        </div>

        <%- include('layouts/footer') %>

<script>
(function() {
  const CSRF = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';

  window.deleteChapter = async function(id) {
    if (!confirm('\u00bfEliminar este cap\u00edtulo? Esta acci\u00f3n no se puede deshacer.')) return;
    try {
      const res = await fetch(`/capitulos/delete/${id}`, {
        method: 'DELETE',
        headers: { 'CSRF-Token': CSRF, 'Accept': 'application/json' }
      });
      if (res.ok) {
        window.location.reload();
      } else {
        const data = await res.json().catch(() => ({}));
        alert(data.error || 'Error al eliminar el cap\u00edtulo.');
      }
    } catch (err) {
      alert('Error de red. Int\u00e9ntalo de nuevo.');
    }
  };
})();
</script>